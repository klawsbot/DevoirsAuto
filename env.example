# Copie ce fichier en .env et remplis les valeurs
# NE JAMAIS mettre le vrai .env sur GitHub

# Identifiants MyCourses IESEG
MOODLE_USER=prenom.nom
MOODLE_PASS=ton_mot_de_passe

# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot
# 1. Parle à @BotFather sur Telegram → /newbot → récupère le token
# 2. Envoie un message à ton bot, puis va sur :
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    pour récupérer ton chat_id
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=ton_chat_id
